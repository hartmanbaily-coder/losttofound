# My Custody Case production environment template.
# Copy these values into the production host secret manager.
# Do not commit a real .env.production file.

NEXT_PUBLIC_APP_URL=https://losttofound.org
NEXT_PUBLIC_RECORDS_HOST=losttofound.org
NEXT_PUBLIC_RECORDS_STORAGE_MODE=supabase
NEXT_PUBLIC_RECORDS_SIGNUPS_ENABLED=false
RECORDS_STORAGE_MODE=supabase
RECORDS_SIGNUPS_ENABLED=false
# Keep true while this installation uses the 4 GiB starter profile. This emits
# a capacity warning but does not block customer use or an App Store release.
STARTER_RESOURCE_PROFILE=true

# Production Supabase project: losttofound-records-production.
NEXT_PUBLIC_SUPABASE_URL=https://cieuilbpnwuvnrxrlczj.supabase.co
EXPECTED_SUPABASE_PROJECT_REF=cieuilbpnwuvnrxrlczj
# Use the active Supabase publishable key named "default" from the production project.
# Prefer the sb_publishable_... key over the legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_DEFAULT_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVER_ONLY_SERVICE_ROLE_KEY

# Auth hardening. Set these only after the matching Supabase dashboard controls are live.
SUPABASE_MFA_POLICY=required
RECORDS_ENFORCE_MFA=true
SUPABASE_CUSTOM_SMTP_ENABLED=true
SUPABASE_AUTH_REDIRECTS_VERIFIED_AT=YYYY-MM-DD
# Supabase Free does not include its native leaked-password toggle. The app-level
# range check below is the required compensating control until Supabase Pro is enabled.
SUPABASE_LEAKED_PASSWORD_PROTECTION_ENABLED=false
PWNED_PASSWORD_CHECK_ENABLED=true
SUPABASE_PASSWORD_MIN_LENGTH=12
SUPABASE_PASSWORD_REAUTH_ENABLED=true
SUPABASE_CURRENT_PASSWORD_REQUIRED=true
SUPABASE_AUTH_HARDENING_VERIFIED_AT=YYYY-MM-DD

# Records storage and session controls.
RECORDS_EVIDENCE_BUCKET=records-evidence
RECORDS_DATASET_MAX_BYTES=2000000
RECORDS_ALLOW_BEARER_AUTH=false
AUTH_SECRET=REPLACE_WITH_32_PLUS_CHARACTER_RANDOM_SECRET
AUTH_TRUST_HOST=true

# Attorney guest lifecycle. Owner shared links may be enabled after deployment
# review. Development links must always stay off in production.
ATTORNEY_GUEST_FEATURE_ENABLED=false
ATTORNEY_PORTAL_SECRET=REPLACE_WITH_SEPARATE_32_PLUS_CHARACTER_RANDOM_SECRET
ATTORNEY_INVITE_OWNER_SHARE_ENABLED=false
ATTORNEY_INVITE_DEV_DELIVERY=false

# Optional AI import assistant. Enable only after vendor/security review.
RECORDS_AI_IMPORT_ENABLED=false
RECORDS_AI_IMPORT_MAX_CHARS=12000
OPENAI_API_KEY=REPLACE_WITH_SERVER_ONLY_OPENAI_API_KEY
OPENAI_IMPORT_MODEL=gpt-5.5

# Evidence intake.
EVIDENCE_MAX_FILE_BYTES=10485760
MALWARE_SCAN_PROVIDER=REPLACE_WITH_clamav_clamd_http_or_webhook
MALWARE_SCANNER_TESTED_AT=YYYY-MM-DD
CLAMAV_HOST=REPLACE_WITH_CLAMAV_HOST
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000
# Starter 4 GiB host profile. At the capacity upgrade, move to at least 8 GiB
# and set CLAMAV_MEMORY_LIMIT=4096m after the reload and malware checks pass.
CLAMAV_MEMORY_LIMIT=2560m
CLAMAV_CPU_LIMIT=1.5
LOSTTOFOUND_MEMORY_LIMIT=768m
CADDY_MEMORY_LIMIT=128m
MALWARE_SCAN_ENDPOINT=
MALWARE_SCAN_API_KEY=

# Security monitoring.
SECURITY_CONTACT_EMAIL=support@lendori.io
PRIVACY_POLICY_URL=https://losttofound.org/privacy
SECURITY_EVENT_SINK=REPLACE_WITH_platform_siem_or_webhook
SECURITY_EVENT_WEBHOOK_URL=
SECURITY_EVENT_WEBHOOK_TOKEN=
SECURITY_LOG_HASH_SALT=REPLACE_WITH_RANDOM_LOG_HASH_SALT

# Edge/provider controls.
EDGE_RATE_LIMITING_ENABLED=true
EDGE_RATE_LIMITING_PROVIDER=REPLACE_WITH_PROVIDER_NAME
EDGE_WAF_ENABLED=true
EDGE_WAF_PROVIDER=REPLACE_WITH_PROVIDER_NAME
SECURITY_MONITORING_ENABLED=true
AUDIT_LOG_REVIEW_ENABLED=true

# Set after the corresponding verification is actually complete.
BACKUP_RESTORE_TESTED_AT=YYYY-MM-DD
TWO_USER_ISOLATION_TESTED_AT=YYYY-MM-DD
DATA_RETENTION_POLICY_APPROVED=true
INCIDENT_RESPONSE_PLAN_APPROVED=true
LEGAL_REVIEW_APPROVED=true
VENDOR_SECURITY_REVIEW_APPROVED=true

# Synthetic live verification helpers. Use synthetic users and data only.
RECORDS_APP_BASE_URL=https://losttofound.org
RECORDS_ISOLATION_EMAIL_DOMAIN=example.test
KEEP_ISOLATION_TEST_USERS=false
