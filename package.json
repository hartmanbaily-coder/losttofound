{
  "name": "losttofound",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:secrets": "node scripts/check-secrets.mjs",
    "security:scan": "npm run security:secrets && npm run security:audit",
    "check:production": "node scripts/check-production-readiness.mjs",
    "check:pre-supabase": "node scripts/check-production-readiness.mjs --pre-supabase",
    "check:live": "node scripts/check-live-readiness.mjs",
    "verify:env-template": "node scripts/verify-production-env-template.mjs",
    "verify:headers": "node scripts/verify-security-headers.mjs",
    "verify:malware": "node scripts/verify-malware-scanner.mjs",
    "verify:isolation": "node scripts/verify-two-user-isolation.mjs",
    "verify:security-events": "node scripts/verify-security-event-sink.mjs",
    "verify:backup-restore": "node scripts/verify-backup-restore-evidence.mjs"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "@supabase/supabase-js": "^2.86.2",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.8.1",
    "vitest": "^4.1.8",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.22",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.18",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
