# My Custody Case
# Copy to .env.local for local development. Do not commit real secrets.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RECORDS_HOST=losttofound.org
NEXT_PUBLIC_RECORDS_STORAGE_MODE=local
NEXT_PUBLIC_RECORDS_SIGNUPS_ENABLED=false
RECORDS_STORAGE_MODE=local

# Production auth/storage target. Supabase mode uses server-side auth routes and
# HttpOnly cookies; local mode remains a synthetic demo store.
RECORDS_SIGNUPS_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=
EXPECTED_SUPABASE_PROJECT_REF=cieuilbpnwuvnrxrlczj
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MFA_POLICY=required
RECORDS_ENFORCE_MFA=false
SUPABASE_CUSTOM_SMTP_ENABLED=false
ATTORNEY_PORTAL_SECRET=replace_with_a_separate_random_secret_at_least_32_characters
ATTORNEY_GUEST_FEATURE_ENABLED=true
ATTORNEY_INVITE_OWNER_SHARE_ENABLED=true
# Development only. Never enable in production.
ATTORNEY_INVITE_DEV_DELIVERY=false
SUPABASE_AUTH_REDIRECTS_VERIFIED_AT=
SUPABASE_LEAKED_PASSWORD_PROTECTION_ENABLED=false
PWNED_PASSWORD_CHECK_ENABLED=false
SUPABASE_PASSWORD_MIN_LENGTH=12
SUPABASE_PASSWORD_REAUTH_ENABLED=false
SUPABASE_CURRENT_PASSWORD_REQUIRED=false
SUPABASE_AUTH_HARDENING_VERIFIED_AT=
RECORDS_EVIDENCE_BUCKET=records-evidence
RECORDS_DATASET_MAX_BYTES=2000000
# Optional non-production diagnostic fallback only. Never enable in production.
RECORDS_ALLOW_BEARER_AUTH=false

# Optional future database URL if Prisma/PostgreSQL is adopted.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/losttofound_records?sslmode=require

# Auth/session secrets must be generated per environment.
# Production AUTH_SECRET must be high entropy and at least 32 chars.
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Production operational controls.
EVIDENCE_MAX_FILE_BYTES=10485760
MALWARE_SCAN_PROVIDER=clamav-or-vendor-name
MALWARE_SCANNER_TESTED_AT=
# ClamAV/clamd provider settings.
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000
# HTTP/webhook scanner settings. Required when MALWARE_SCAN_PROVIDER=http or webhook.
MALWARE_SCAN_ENDPOINT=
MALWARE_SCAN_API_KEY=
SECURITY_CONTACT_EMAIL=security@example.invalid
PRIVACY_POLICY_URL=https://losttofound.org/privacy
SECURITY_EVENT_SINK=platform-or-siem
SECURITY_EVENT_WEBHOOK_URL=
SECURITY_EVENT_WEBHOOK_TOKEN=
SECURITY_LOG_HASH_SALT=

# Production launch gates. Set only after the corresponding control is live and verified.
EDGE_RATE_LIMITING_ENABLED=false
EDGE_RATE_LIMITING_PROVIDER=cloudflare-or-provider
EDGE_WAF_ENABLED=false
EDGE_WAF_PROVIDER=cloudflare-or-provider
SECURITY_MONITORING_ENABLED=false
AUDIT_LOG_REVIEW_ENABLED=false
BACKUP_RESTORE_TESTED_AT=
TWO_USER_ISOLATION_TESTED_AT=
DATA_RETENTION_POLICY_APPROVED=false
INCIDENT_RESPONSE_PLAN_APPROVED=false
LEGAL_REVIEW_APPROVED=false
VENDOR_SECURITY_REVIEW_APPROVED=false

# Synthetic live verification helpers. Use only with test data.
RECORDS_APP_BASE_URL=http://127.0.0.1:3000
RECORDS_ISOLATION_EMAIL_DOMAIN=example.test
KEEP_ISOLATION_TEST_USERS=false

# CI runs `npm run check:production` explicitly before production deploy.
